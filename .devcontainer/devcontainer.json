{
  "name": "Claude Meta-AutoAgent",
  "dockerComposeFile": "docker-compose.yml",
  "service": "claude-devcontainer",
  "workspaceFolder": "/workspaces",

  "containerEnv": {
    "DEVCONTAINER": "true",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8"
  },

  "remoteEnv": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0"
  },

  "features": {},

  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": null,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.rulers": [120],
        "files.encoding": "utf8",
        "files.eol": "\n",
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/node_modules/**": true,
          "**/__pycache__/**": true
        }
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "forwardPorts": [3000, 8080, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "App", "onAutoForward": "notify" },
    "8080": { "label": "API", "onAutoForward": "notify" },
    "5432": { "label": "Database", "onAutoForward": "silent" },
    "6379": { "label": "Extra", "onAutoForward": "silent" }
  },

  "postCreateCommand": "/usr/local/bin/setup-env.sh",
  "postStartCommand": "git config core.filemode false 2>/dev/null || true",
  "waitFor": "postCreateCommand",

  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "init": true,
  "shutdownAction": "stopCompose",

  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,consistency=cached",
    "source=claude-config-${devcontainerId},target=/home/vscode/.claude,type=volume",
    "source=command-history-${devcontainerId},target=/commandhistory,type=volume"
  ]
}
