# =============================================================================
# DevContainer Configuration
# =============================================================================
# After changes: Ctrl+Shift+P -> "Rebuild Container"
# =============================================================================

# --- Identity ---
COMPOSE_PROJECT_NAME=claude-meta-autoagent
CONTAINER_NAME=claude-meta-autoagent
IMAGE_NAME=claude-devcontainer
IMAGE_TAG=latest

# --- Runtime ---
TZ=UTC

# --- Node.js ---
# For project use (leave empty to skip project Node.js installation)
PROJECT_NODE_VERSION=

# --- Ports ---
# Must be synced with devcontainer.json forwardPorts
PORT_APP=3000
PORT_API=8080
PORT_DB=5432
PORT_EXTRA=6379

# --- Workspace ---
# Set to the HOST filesystem path of this project.
# Windows example: /c/Workspace/Projects/claude-meta-autoagent
# Leave empty to use parent of .devcontainer
HOST_WORKSPACE_PATH=
