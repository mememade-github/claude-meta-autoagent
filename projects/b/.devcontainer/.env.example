# =============================================================================
# projects/b — Level-3b Sub-project DevContainer Configuration
# =============================================================================
# Copy to .env and customize for your environment:
#   cp .env.example .env
# Ports offset from ROOT (5xxx vs 3xxx) and from projects/a (4xxx).
# =============================================================================

COMPOSE_PROJECT_NAME=claude-meta-autoagent-b
CONTAINER_NAME=claude-meta-autoagent-b
IMAGE_NAME=claude-devcontainer-b
IMAGE_TAG=latest

TZ=UTC

PROJECT_NODE_VERSION=

# Ports — offset from ROOT and from projects/a
PORT_APP=5000
PORT_API=5080

# Set to HOST filesystem path of projects/b/
# Leave empty to use parent of .devcontainer (works for simple setups)
HOST_WORKSPACE_PATH=
