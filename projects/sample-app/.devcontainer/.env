# =============================================================================
# sample-app — Sub-project DevContainer Configuration
# =============================================================================
# Ports offset from ROOT (4xxx vs 3xxx) to allow simultaneous operation.
# =============================================================================

COMPOSE_PROJECT_NAME=sample-app
CONTAINER_NAME=sample-app
IMAGE_NAME=claude-devcontainer-sample
IMAGE_TAG=latest

TZ=UTC

PROJECT_NODE_VERSION=

# Ports — offset from ROOT to avoid collision
PORT_APP=4000
PORT_API=4080

# Set to HOST filesystem path of projects/sample-app/
HOST_WORKSPACE_PATH=
