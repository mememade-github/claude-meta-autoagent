# =============================================================================
# projects/a — Level-3a Sub-project DevContainer Configuration
# =============================================================================
# Copy to .env and customize for your environment:
#   cp .env.example .env
# Ports offset from ROOT (4xxx vs 3xxx) to allow simultaneous operation.
# =============================================================================

COMPOSE_PROJECT_NAME=claude-meta-autoagent-a
CONTAINER_NAME=claude-meta-autoagent-a
IMAGE_NAME=claude-devcontainer-a
IMAGE_TAG=latest

TZ=UTC

PROJECT_NODE_VERSION=

# Ports — offset from ROOT to avoid collision
PORT_APP=4000
PORT_API=4080

# Set to HOST filesystem path of projects/a/
# Leave empty to use parent of .devcontainer (works for simple setups)
HOST_WORKSPACE_PATH=
