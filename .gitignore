# Python
__pycache__/
*.py[oc]
.venv/

# Node
node_modules/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Credentials — never commit
.env/
*.env
!.env.example

# Agent runtime artifacts (generated per-session)
.claude/agent-memory/
.claude/.refinement-active
.claude/.refine-output
.claude/.refine-eval*
.claude/.last-*
.claude/.update-check-cache
.claude/worktrees/
.claude/.delegate-log/
# Sub-project agent runtime artifacts (same classes, any sub-project)
**/.claude/.refinement-active
**/.claude/.refine-output
**/.claude/.refine-eval*
**/.claude/.last-*
**/.claude/.update-check-cache
**/.claude/worktrees/
**/.claude/.delegate-log/
**/.claude/agent-memory/

# Refinement attempts (session-specific)
.refine-output
projects/*/attempts/

# WIP tasks (session-specific)
wip/

# Test runner logs (reproduced on every invocation)
tests/results/

# Sub-projects — part of the ROOT system. Sub-projects not listed below are
# gitignored from the public repo but remain internal to the ROOT system.
# To track a new sub-project: add !projects/<name>/ below.
projects/*/
!projects/a/
!projects/b/

# Cycle deliverables — regenerated per cycle in A/B containers.
# Permanent snapshots live under docs/research/eml-paper/cycle-NN/.
projects/a/task/
projects/b/task/
