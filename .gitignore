# Python
__pycache__/
*.py[oc]
.venv/

# Node
node_modules/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Credentials — never commit
.env/
*.env
!.env.example

# Agent runtime artifacts (generated per-session)
.claude/agent-memory/
.claude/.refinement-active
.claude/.refine-output
.claude/.last-*
.claude/.update-check-cache
.claude/worktrees/
.claude/.delegate-log/

# Refinement attempts (session-specific)
.refine-output
projects/*/attempts/

# WIP tasks (session-specific)
wip/

# Sub-projects — part of ROOT system, but only sample-app is public.
# New sub-projects (e.g. projects/my-project/) are gitignored from the
# public repo but remain internal to the ROOT system architecture.
# To track a new sub-project: add !projects/my-project/ below.
projects/*/
!projects/sample-app/
